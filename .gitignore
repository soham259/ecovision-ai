@"
# Secrets - NEVER commit
.env
.streamlit/

# Python
__pycache__/
*.pyc
*.pyo
venv/
.venv/
env/

# OS junk
.DS_Store
Thumbs.db

# Large model weights (Whisper only — DistilBERT is committed via LFS)
models/whisper/*.safetensors
models/whisper/*.bin
models/whisper/**/*.safetensors
models/whisper/**/*.bin

# Jupyter checkpoints
.ipynb_checkpoints/

# Temp/output folders
outputs/
temp/
"@ | Out-File -Encoding utf8 .gitignore